<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
  <LinearLayout
      android:orientation="vertical"
      android:layout_width="fill_parent"
      android:layout_height="wrap_content"
      android:layout_margin="12dip">

    <Spinner
        android:id="@+id/s3_provider"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:entries="@array/s3_providers" />

    <EditText
        android:id="@+id/s3_region"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:inputType="textNoSuggestions"
        android:text=""
        android:hint="@string/hint_s3_region" />

    <EditText
        android:id="@+id/s3_endpoint"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:inputType="textWebEmailAddress"
        android:text=""
        android:visibility="gone"
        android:hint="@string/hint_s3_endpoint" />

    <EditText
        android:id="@+id/s3_account_id"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:inputType="textNoSuggestions"
        android:text=""
        android:visibility="gone"
        android:hint="@string/hint_s3_account_id" />

    <EditText
        android:id="@+id/s3_bucket"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:inputType="textNoSuggestions"
        android:text=""
        android:hint="@string/hint_s3_bucket" />

    <EditText
        android:id="@+id/s3_access_key"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:inputType="textNoSuggestions"
        android:text=""
        android:hint="@string/hint_s3_access_key" />

    <EditText
        android:id="@+id/s3_secret_key"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:inputType="textPassword"
        android:text=""
        android:importantForAccessibility="no"
        android:hint="@string/hint_s3_secret_key" />

    <TextView
        android:id="@+id/s3_object_key_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dip"
        android:layout_marginTop="4dip"
        android:text="@string/s3_object_key_label" />

    <EditText
        android:id="@+id/s3_object_key"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:inputType="textNoSuggestions"
        android:text=""
        android:hint="@string/hint_s3_object_key" />

    <TextView
        android:id="@+id/s3_url_preview_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dip"
        android:layout_marginTop="12dip"
        android:text="@string/s3_url_preview_label" />

    <TextView
        android:id="@+id/s3_url_preview"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dip"
        android:layout_marginTop="2dip"
        android:textIsSelectable="true"
        android:typeface="monospace"
        android:textColor="?android:attr/textColorSecondary"
        android:text="" />

  </LinearLayout>
</ScrollView>
